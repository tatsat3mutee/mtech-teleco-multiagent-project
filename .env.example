# -----------------------------------------------------------------
# Multi-Agent RCA — LLM Provider Config (2 keys, rate-limit-aware router)
# Copy to `.env`. Set at least GROQ_API_KEY. OpenRouter is the fallback.
# -----------------------------------------------------------------

# -- Groq (priority 1, free tier, GPT OSS 120B) --  https://console.groq.com/
GROQ_API_KEY=gsk_xxxxx

# -- OpenRouter (fallback, free models: DeepSeek R1, Llama 3.3, DeepSeek Chat)
# Get key at https://openrouter.ai/  (free account, add $1 credit to unlock higher rate limits)
OPENROUTER_API_KEY=sk-or-xxxxx

# -- Optional: cross-family judge for evaluation (defaults to Groq if unset) --
# JUDGE_API_KEY=sk-or-xxxxx
# JUDGE_BASE_URL=https://openrouter.ai/api/v1
# JUDGE_MODEL=openai/gpt-oss-120b

# -- Rate limits (used by legacy token-bucket middleware) --
LLM_RATE_PER_MIN=28
LLM_BUCKET_CAPACITY=10

# -----------------------------------------------------------------
# Inference Logging — PostgreSQL (Neon.tech free tier)
# Defaults to SQLite (inferences.db) when unset.
# -----------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------
# Observability — Langfuse (cloud or self-hosted)
# -----------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------
# Redis (only needed if not using docker-compose default)
# -----------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------
# API Security — REQUIRED for any public deployment (AWS EC2)
# -----------------------------------------------------------------
# Auth for FastAPI /rca/run — leave unset ONLY for local dev
# RCA_API_KEY=choose-a-long-random-string
# Comma-separated allowed origins — set to your public URL(s)
# CORS_ORIGINS=http://<EC2_PUBLIC_IP>:8501,http://<EC2_PUBLIC_IP>
