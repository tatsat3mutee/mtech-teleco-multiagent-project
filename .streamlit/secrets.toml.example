# Streamlit Community Cloud secrets template
# Copy to .streamlit/secrets.toml and fill in your API keys.
# secrets.toml is in .gitignore — never commit it.
#
# Usage in Streamlit Cloud:
#   Settings > Secrets > paste the contents of this file (with real keys)
#
# The app's load_secrets() function automatically reads these into os.environ
# so config.py picks them up without any code changes.

GROQ_API_KEY = ""          # Required — free at console.groq.com
GEMINI_API_KEY = ""        # Optional — aistudio.google.com
DEEPSEEK_API_KEY = ""      # Optional — platform.deepseek.com
KIMI_API_KEY = ""          # Optional — platform.moonshot.ai
